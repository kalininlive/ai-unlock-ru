{
  "manifest_version": 3,
  "name": "AI SERVICE UNBLOCK",
  "version": "1.1.0",
  "description": "Premium AI Unblocker. Routing specific AI domains through your proxy with Glassmorphism UI.",
  "author": "Antigravity & Aimagine-life",
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI SERVICE UNBLOCK",
    "default_icon": {
      "16": "icons/off-16.png",
      "32": "icons/off-32.png",
      "48": "icons/off-48.png",
      "128": "icons/off-128.png"
    }
  },
  "icons": {
    "16": "icons/off-16.png",
    "32": "icons/off-32.png",
    "48": "icons/off-48.png",
    "128": "icons/off-128.png"
  },
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider",
    "tabs",
    "alarms",
    "unlimitedStorage",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": []
  }
}
